        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson && responseJson.token) {",
                  "    pm.environment.set(\"accessToken\", responseJson.token);",
                  "    console.log(\"Saved access token to environment variable 'accessToken'\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student.doe@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
